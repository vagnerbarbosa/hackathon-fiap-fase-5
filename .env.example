# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fiap_stride

# Redis (for rate limiting and cache)
REDIS_URL=redis://localhost:6379/0

# File Storage
STORAGE_PATH=./storage

# Logging
LOG_LEVEL=INFO

# Security
API_RATE_LIMIT=60
API_KEY=your-secure-api-key-here

# CORS (comma-separated list, empty for development)
CORS_ORIGINS=
