# Project specific
# -------------------------------

# Model artifacts (large binaries — use Git LFS or release assets)
models/*.pt
models/*.onnx
models/*.pth
models/*.safetensors

# Ultralytics training runs (checkpoints, plots, logs — not versioned)
runs/

